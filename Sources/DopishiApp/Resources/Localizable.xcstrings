    "settings.electronSupport" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Electron app support" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Поддержка Electron-приложений" } }
      }
    },
    "settings.system.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Electron support enables text reading in Claude, VS Code and similar apps (fixes and layout). It may affect window managers (Magnet, Rectangle) - enable when needed." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Поддержка Electron включает чтение текста в Claude, VS Code и подобных (исправления и раскладка). Может влиять на оконные менеджеры (Magnet, Rectangle) - включайте при необходимости." } }
      }
    },
    "settings.context.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Context" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Контекст" } }
      }
    },
    "settings.context.ocr" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Screen context (OCR)" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Контекст экрана (OCR)" } }
      }
    },
    "settings.context.openScreenRecording" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Open screen recording settings…" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Открыть настройки записи экрана…" } }
      }
    },
    "settings.context.clipboard" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Clipboard context" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Контекст буфера обмена" } }
      }
    },
    "settings.context.memory" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Memory (remember what was written in the window)" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Память (помнить написанное в окне)" } }
      }
    },
    "settings.context.clearMemory" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Clear memory…" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Очистить память…" } }
      }
    },
    "settings.context.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Suggestions take into account the text around the field (email subject, recipient, title), recently copied text and the history of what you wrote in this window. Everything is local (SQLite on your Mac), nothing goes to the network. OCR requires Screen Recording. The clipboard is mixed in only if it is fresh (<5 min) and overlaps with what you are typing. Memory is kept for 7 days (configurable in Privacy), secrets are not recorded. Nothing works in secure fields and excluded apps." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Подсказки учитывают текст вокруг поля (тема письма, собеседник, заголовок), недавно скопированный текст и историю того, что вы писали в этом окне. Всё локально (SQLite на вашем Mac), ничего не уходит в сеть. OCR требует «Запись экрана». Буфер подмешивается только если свежий (<5 мин) и пересекается с тем, что вы печатаете. Память хранится 7 дней (настраивается в «Приватность…»), секреты не записываются. Ничего не работает в secure-полях и исключённых приложениях." } }
      }
    },
    "settings.suggestions.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Suggestions" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Подсказки" } }
      }
    },
    "settings.suggestions.show" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Show suggestions" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Показывать подсказки" } }
      }
    },
    "settings.suggestions.debounce" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Delay: %lld ms" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Задержка: %lld мс" } }
      }
    },
    "settings.suggestions.minChars" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Minimum characters: %lld" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Минимум символов: %lld" } }
