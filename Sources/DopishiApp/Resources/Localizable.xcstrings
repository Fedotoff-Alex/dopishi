      }
    },
    "settings.model.deleteHelp" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Delete the model from disk" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Удалить модель с диска" } }
      }
    },
    "settings.model.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "%@ The download is verified by checksum (sha256); an interrupted one resumes from the place of cancellation." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "%@ Загрузка проверяется по контрольной сумме (sha256); прерванная - продолжается с места отмены." } }
      }
    },
    "settings.corrections.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Corrections" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Исправления" } }
      }
    },
    "settings.corrections.manualLayout" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Switch layout on Option tap" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Переключать раскладку по тапу Option" } }
      }
    },
    "settings.corrections.autoLayout" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Automatic layout switching" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Автопереключение раскладки" } }
      }
    },
    "settings.corrections.autocorrect" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Suggest typo fixes (in green, Tab)" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Предлагать исправление опечаток (зелёным, Tab)" } }
      }
    },
    "settings.corrections.disableSystem" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Suppress macOS system autocorrect" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Гасить системное автоисправление macOS" } }
      }
    },
    "settings.corrections.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A typo is not replaced by itself - a fix is offered as a green ghost, Tab replaces the word. The macOS system autocorrect can be suppressed so it does not conflict (applied after restarting the app)." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Опечатка не заменяется сама - предлагается исправление зелёным призраком, Tab заменяет слово. Системное автоисправление macOS можно погасить, чтобы оно не конфликтовало (применяется после перезапуска приложения)." } }
      }
    },
    "settings.dictionary.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Personal dictionary" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Личный словарь" } }
      }
    },
    "settings.dictionary.addPlaceholder" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add a word…" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добавить слово…" } }
      }
    },
    "settings.dictionary.add" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добавить" } }
      }
    },
    "settings.dictionary.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Words here are not treated as typos and are not offered for correction - names, projects, terms, slang (like the PuntoSwitcher ignore list)." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Слова отсюда не считаются опечаткой и не предлагаются к исправлению - имена, проекты, термины, сленг (как игнор-словарь PuntoSwitcher)." } }
      }
    },
    "settings.style.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Style guidelines" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Указания по стилю" } }
      }
    },
    "settings.style.placeholder" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "E.g.: write briefly and in a business tone, no fluff" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Напр.: пиши кратко и по-деловому, без воды" } }
      }
    },
    "settings.style.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Mixed into the beginning of the prompt, they affect the style/tone of completions. Empty - no guidelines." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Подмешиваются в начало промпта, влияют на стиль/тон продолжений. Пусто - без указаний." } }
      }
    },
    "settings.snippets.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Snippets" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Сниппеты" } }
      }
    },
    "settings.snippets.placeholder" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "sig: Best regards, Alex\naddr: 27c1 Pavlovskaya St." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "sig: С уважением, Алекс\naddr: Павловская 27с1" } }
      }
    },
    "settings.snippets.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "One line = \"name: text\". Type :name and press Tab - the text is inserted. Built-in: :date (date) and :time (time)." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Одна строка = «имя: текст». Набери :имя и нажми Tab - текст вставится. Встроенные: :date (дата) и :time (время)." } }
      }
    },
    "settings.exclusions.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Do not work in apps" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Не работать в приложениях" } }
      }
    },
    "settings.exclusions.addApp" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add an app…" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добавить приложение…" } }
      }
    },
    "settings.exclusions.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Dopishi works in all apps. Here is where to fully disable it (suggestions, automatic and manual switching)." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Dopishi работает во всех приложениях. Здесь - где полностью выключить (подсказки, авто- и ручное переключение)." } }
      }
    },
    "settings.models.count" : {
      "localizations" : {
        "en" : {
          "variations" : {
            "plural" : {
              "one" : { "stringUnit" : { "state" : "translated", "value" : "%lld model" } },
              "other" : { "stringUnit" : { "state" : "translated", "value" : "%lld models" } }
            }
          }
        },
        "ru" : {
          "variations" : {
            "plural" : {
