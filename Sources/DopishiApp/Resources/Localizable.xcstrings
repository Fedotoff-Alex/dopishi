    "privacy.memory.clear" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Clear memory…" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Очистить память…" } }
      }
    },
    "privacy.memory.export" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Export…" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Экспортировать…" } }
      }
    },
    "privacy.memory.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Memory is local (SQLite on your Mac), nothing goes to the network. Clearing removes both memory records and suggestion statistics. Export saves the records to a JSON file." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Память локальная (SQLite на вашем Mac), ничего не уходит в сеть. Очистка удаляет и записи памяти, и статистику подсказок. Экспорт сохраняет записи в JSON-файл." } }
      }
    },
    "privacy.exclusions.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Do not learn in apps" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Не учиться в приложениях" } }
      }
    },
    "privacy.exclusions.addApp" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add an app…" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добавить приложение…" } }
      }
    },
    "privacy.exclusions.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Suggestions in these apps work, but what is written in them is NOT recorded into memory (a messenger with personal chats, work email, etc.)." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Подсказки в этих приложениях работают, но написанное в них НЕ записывается в память (мессенджер с личным, рабочая почта и т.п.)." } }
      }
    },
    "privacy.stats.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Statistics" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Статистика" } }
      }
    },
    "privacy.stats.toggle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Local suggestion statistics" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Локальная статистика подсказок" } }
      }
    },
    "privacy.stats.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Metadata only: outcome (shown/accepted/rejected), latency, app, model. Text is NOT saved. Powers diagnostics metrics and adaptive threshold tuning. Kept for 7 days." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Только метаданные: исход (показана/принята/отклонена), задержка, приложение, модель. Текст НЕ сохраняется. Питает метрики диагностики и адаптивную подстройку порогов. Хранится 7 дней." } }
      }
    },
    "privacy.storage.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Storage" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Хранилище" } }
      }
    },
    "privacy.storage.dbSize" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Database size" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Размер базы" } }
      }
