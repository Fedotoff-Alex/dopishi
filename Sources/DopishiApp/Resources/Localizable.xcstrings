        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Отмена" } }
      }
    },
    "settings.model.cancelHelp" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Interrupt the download - it will resume from the same place" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Прервать загрузку - продолжится с того же места" } }
      }
    },
    "settings.model.inUse" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "in use" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "используется" } }
      }
    },
    "settings.model.speed" : {
      "localizations" : {
