    "privacy.pause.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Full pause: suggestions, corrections and memory recording are off until you turn it back on." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Полная пауза: подсказки, исправления и запись памяти выключены, пока не включите обратно." } }
      }
    },
    "privacy.memory.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Memory" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Память" } }
      }
    },
    "privacy.memory.toggle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Memory (remember what was written in the window)" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Память (помнить написанное в окне)" } }
      }
    },
    "privacy.memory.keep" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Keep records" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Хранить записи" } }
      }
