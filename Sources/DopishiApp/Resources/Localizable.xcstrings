    "diagnostics.refusals.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Only refusals for an explicit suggestion request: no caret position, empty field, stale context. Auto-suggestion refusals (secure field, excluded app, too little typed) are not recorded here - the current reason is visible in the \"Last outcome\" row." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Только отказы по явному запросу подсказки: нет позиции каретки, пустое поле, устаревший контекст. Отказы автоподсказки (secure-поле, исключённое приложение, мало набрано) сюда не пишутся - текущую причину видно в строке «Последний исход»." } }
      }
