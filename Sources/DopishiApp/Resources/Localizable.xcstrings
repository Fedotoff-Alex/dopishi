      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "How many times the privacy guard dropped a fragment with a detected secret (API key, token, private key) before it could reach memory. Only the count is stored - never the text itself." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Сколько раз защита приватности отбросила фрагмент с найденным секретом (API-ключ, токен, приватный ключ) до того, как он попал бы в память. Хранится только число - никогда сам текст." } }
