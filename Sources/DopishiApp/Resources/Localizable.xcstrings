    "onboarding.test.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Type a couple of words - a continuation will appear in gray. Tab accepts the word, ` (the key above Tab) accepts the whole phrase, Esc hides it." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Напишите пару слов - серым появится продолжение. Tab принимает слово, ` (клавиша над Tab) - всю фразу, Esc прячет." } }
      }
    },
    "onboarding.test.warmup" : {
