        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Длина дополнения: до %lld слов" } }
      }
    },
    "settings.model.header" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Model" } },
