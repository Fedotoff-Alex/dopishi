      }
    },
    "privacy.storage.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "~/Library/Application Support/Dopishi/memory.sqlite - accessible only to your user (mode 0600). There is no file-level encryption; a FileVault disk encrypts it entirely." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "~/Library/Application Support/Dopishi/memory.sqlite - доступ только у вашего пользователя (права 0600). Шифрования на уровне файла нет; диск с FileVault шифрует его целиком." } }
      }
    },
    "privacy.ttl.days" : {
      "localizations" : {
        "en" : {
          "variations" : {
            "plural" : {
              "one" : { "stringUnit" : { "state" : "translated", "value" : "%lld day" } },
