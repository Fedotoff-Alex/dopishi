    "onboarding.model.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Suggestions are generated by a local model. Select and download one (you can change it later in settings)." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Подсказки генерирует локальная модель. Выберите и скачайте одну (можно сменить позже в настройках)." } }
