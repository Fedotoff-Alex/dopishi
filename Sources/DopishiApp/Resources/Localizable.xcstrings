    "onboarding.welcome.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Dopishi" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Допиши" } }
      }
    },
    "onboarding.welcome.body" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A local autocomplete for the whole Mac: it completes phrases in any app, fixes typos and keyboard layout. The model runs on your Mac - the text is not sent anywhere." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Локальный автокомплит для всего Mac: дописывает фразы в любом приложении, исправляет опечатки и раскладку. Модель работает на вашем Mac - текст никуда не отправляется." } }
      }
    },
    "onboarding.welcome.steps" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The wizard will guide you step by step: two system permissions, model selection and a test in a sample field." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Мастер проведёт по шагам: два системных разрешения, выбор модели и проверка в тестовом поле." } }
      }
    },
    "onboarding.accessibility.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Step 1 of 4: Accessibility" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Шаг 1 из 4: Accessibility" } }
      }
    },
    "onboarding.accessibility.explanation" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "To see the text and caret position in the active field, Dopishi needs the Accessibility permission." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Чтобы видеть текст и позицию каретки в активном поле, Допиши нужно разрешение «Универсальный доступ» (Accessibility)." } }
      }
    },
    "onboarding.accessibility.grant" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Grant Accessibility…" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Выдать Accessibility…" } }
      }
    },
    "onboarding.inputMonitoring.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Step 2 of 4: Input Monitoring" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Шаг 2 из 4: Input Monitoring" } }
      }
    },
    "onboarding.inputMonitoring.explanation" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "To react to typing and the Tab key, the Input Monitoring permission is needed." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Чтобы реагировать на набор и клавишу Tab, нужно разрешение «Мониторинг ввода» (Input Monitoring)." } }
      }
    },
    "onboarding.inputMonitoring.grant" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Grant Input Monitoring…" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Выдать Input Monitoring…" } }
      }
    },
